{
    "$schema": "node_modules/wrangler/config-schema.json",
    "name": "kissai",
    "main": "worker.js",
    "compatibility_date": "2026-05-12",
    "observability": {
        "enabled": true
    },
    "assets": {
        "directory": ".",
        "binding": "ASSETS",
        "run_worker_first": [
            "/api/proxy/*"
        ]
    },
    "workers_dev": true,
    "preview_urls": true
}
